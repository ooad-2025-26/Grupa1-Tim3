@page
@model EVrtic.Areas.Identity.Pages.Account.RegisterModel
@using EVrtic.Models

@{
    ViewData["Title"] = "Registracija";
}

<div class="register-page">
    <div class="register-card">

        <section class="register-left">
            <div class="register-sun">☀</div>
            <div class="register-cloud cloud-a"></div>
            <div class="register-cloud cloud-b"></div>

            <div class="register-logo">eVrtić</div>
            <h2>Dobro došli!</h2>
            <p>Kreirajte svoj korisnički nalog</p>

            <div class="register-illustration">
                <div class="register-school">
                    <div class="register-roof"></div>
                    <div class="register-building">
                        <div class="register-window"></div>
                        <div class="register-door"></div>
                        <div class="register-window"></div>
                    </div>
                </div>
                <div class="register-kids">
                    <span>🧒</span>
                    <span>👧</span>
                    <span>👦</span>
                </div>
            </div>
        </section>

        <section class="register-right">
            <div class="register-box">
                <h3>Registrujte se</h3>

                <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

                    <div class="register-input">
                        <span>👤</span>
                        <input asp-for="Input.ImePrezime" placeholder="Ime i prezime" autocomplete="name" />
                    </div>
                    <span asp-validation-for="Input.ImePrezime" class="text-danger"></span>

                    <div class="register-input">
                        <span>✉</span>
                        <input asp-for="Input.Email" placeholder="Email" autocomplete="username" />
                    </div>
                    <span asp-validation-for="Input.Email" class="text-danger"></span>

                    <div class="register-input">
                        <span>🔒</span>
                        <input asp-for="Input.Password" placeholder="Lozinka" autocomplete="new-password" />
                    </div>
                    <span asp-validation-for="Input.Password" class="text-danger"></span>

                    <div class="register-input">
                        <span>🔒</span>
                        <input asp-for="Input.ConfirmPassword" placeholder="Potvrda lozinke" autocomplete="new-password" />
                    </div>
                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>

                    <div class="register-input">
                        <span>👥</span>
                        <select asp-for="Input.Uloga" id="ulogaSelect">
                            <option value="">Odaberite ulogu</option>
                            <option value="RODITELJ">Roditelj</option>
                            <option value="ODGAJATELJ">Odgajatelj</option>
                        </select>
                    </div>
                    <span asp-validation-for="Input.Uloga" class="text-danger"></span>

                    <div id="roditeljPolja" style="display:none;">

                        <div class="register-input">
                            <span>📱</span>
                            <input asp-for="Input.KontaktTelefon" placeholder="Kontakt telefon" autocomplete="tel" />
                        </div>
                        <span asp-validation-for="Input.KontaktTelefon" class="text-danger"></span>

                        <div class="register-input">
                            <span>🔑</span>
                            <input asp-for="Input.IdentifikacioniKodDjeteta" placeholder="Identifikacioni kod djeteta" />
                        </div>
                        <span asp-validation-for="Input.IdentifikacioniKodDjeteta" class="text-danger"></span>

                    </div>

                    <button id="registerSubmit" type="submit" class="register-button">
                        Registrujte se
                    </button>

                    <div class="login-link">
                        Već imate račun?
                        <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl">
                            Prijavite se
                        </a>
                    </div>
                </form>
            </div>
        </section>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        function prikaziRoditeljPolja() {
            const uloga = document.getElementById("ulogaSelect").value;
            document.getElementById("roditeljPolja").style.display =
                uloga === "RODITELJ" ? "block" : "none";
        }

        document.getElementById("ulogaSelect").addEventListener("change", prikaziRoditeljPolja);
        prikaziRoditeljPolja();
    </script>
}
