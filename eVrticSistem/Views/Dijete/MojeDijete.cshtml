@model EVrtic.Models.Dijete
@{
    ViewData["Title"] = "Moje dijete";
}

<div style="min-height:100vh; background:#bfdbfe; display:flex; align-items:flex-start; justify-content:center; padding:40px 20px;">
    <div style="width:100%; max-width:640px; display:flex; flex-direction:column; gap:16px;">

        @* Header *@
        <div style="background:linear-gradient(135deg,#f97316,#fb923c); border-radius:24px; padding:28px 32px; display:flex; align-items:center; gap:20px; box-shadow:0 8px 32px rgba(249,115,22,0.3);">
            <div style="background:rgba(255,255,255,0.25); border-radius:50%; width:64px; height:64px; display:flex; align-items:center; justify-content:center; font-size:2rem; flex-shrink:0;">
                👶
            </div>
            <div style="flex:1; min-width:0;">
                <h2 style="margin:0 0 4px; color:#fff; font-size:1.5rem; font-weight:800;">@Model.ImePrezime</h2>
                <p style="margin:0; color:rgba(255,255,255,0.85); font-size:0.88rem;">
                    Profil djeteta &nbsp;·&nbsp; Kod: <strong>@Model.IdentifikacioniKod</strong>
                </p>
            </div>
            <a asp-action="UnosPodataka"
               style="background:rgba(255,255,255,0.2); backdrop-filter:blur(4px); border:1.5px solid rgba(255,255,255,0.4); color:#fff; border-radius:12px; padding:10px 20px; text-decoration:none; font-weight:600; font-size:0.9rem; white-space:nowrap;">
                ✏️ Uredi
            </a>
        </div>

        @* Osnovne informacije *@
        <div style="background:#fff; border-radius:20px; padding:24px 28px; box-shadow:0 2px 12px rgba(0,0,0,0.05);">
            <div style="font-weight:700; color:#475569; font-size:0.8rem; text-transform:uppercase; letter-spacing:.06em; margin-bottom:16px;">
                📋 Osnovne informacije
            </div>
            <div style="display:flex; flex-direction:column; gap:10px;">
                <div style="display:flex; align-items:center; gap:12px;">
                    <span style="font-size:1.1rem">🎂</span>
                    <div>
                        <div style="font-size:0.78rem; color:#94a3b8; font-weight:600; text-transform:uppercase; letter-spacing:.04em;">Datum rođenja</div>
                        <div style="color:#1e293b; font-weight:600; margin-top:2px;">
                            @(Model.DatumRodjenja != default
                                ? Model.DatumRodjenja.ToString("dd.MM.yyyy")
                                : "Nije uneseno")
                        </div>
                    </div>
                </div>
                @if (!string.IsNullOrWhiteSpace(Model.DodatnaNapomena))
                {
                    <div style="display:flex; align-items:flex-start; gap:12px;">
                        <span style="font-size:1.1rem; margin-top:2px;">📝</span>
                        <div>
                            <div style="font-size:0.78rem; color:#94a3b8; font-weight:600; text-transform:uppercase; letter-spacing:.04em;">Napomena</div>
                            <div style="color:#334155; margin-top:2px; line-height:1.5;">@Model.DodatnaNapomena</div>
                        </div>
                    </div>
                }
            </div>
        </div>

        @* Alergije *@
        <div style="background:#fff; border-radius:20px; padding:24px 28px; box-shadow:0 2px 12px rgba(0,0,0,0.05);">
            <div style="font-weight:700; color:#475569; font-size:0.8rem; text-transform:uppercase; letter-spacing:.06em; margin-bottom:16px;">
                ⚠️ Alergije
            </div>
            @if (Model.Alergije.Any())
            {
                <div style="display:flex; flex-wrap:wrap; gap:10px;">
                    @foreach (var a in Model.Alergije)
                    {
                        <span style="background:#fff1f2; border:1.5px solid #fecdd3; color:#be123c; border-radius:50px; padding:8px 18px; font-size:0.9rem; font-weight:600; display:flex; align-items:center; gap:6px;">
                            🌿 @a.Naziv
                        </span>
                    }
                </div>
            }
            else
            {
                <p style="margin:0; color:#94a3b8; font-size:0.9rem;">Nema unesenih alergija.</p>
            }
        </div>

        @* Bolesti *@
        <div style="background:#fff; border-radius:20px; padding:24px 28px; box-shadow:0 2px 12px rgba(0,0,0,0.05);">
            <div style="font-weight:700; color:#475569; font-size:0.8rem; text-transform:uppercase; letter-spacing:.06em; margin-bottom:16px;">
                🏥 Bolesti / hronična stanja
            </div>
            @if (Model.Bolesti.Any())
            {
                <div style="display:flex; flex-wrap:wrap; gap:10px;">
                    @foreach (var b in Model.Bolesti)
                    {
                        <span style="background:#eff6ff; border:1.5px solid #bfdbfe; color:#1d4ed8; border-radius:50px; padding:8px 18px; font-size:0.9rem; font-weight:600; display:flex; align-items:center; gap:6px;">
                            💊 @b.Naziv
                        </span>
                    }
                </div>
            }
            else
            {
                <p style="margin:0; color:#94a3b8; font-size:0.9rem;">Nema unesenih bolesti.</p>
            }
        </div>

        @* Grupa *@
        @if (Model.Grupa != null)
        {
            <div style="background:#fff; border-radius:20px; padding:24px 28px; box-shadow:0 2px 12px rgba(0,0,0,0.05);">
                <div style="font-weight:700; color:#475569; font-size:0.8rem; text-transform:uppercase; letter-spacing:.06em; margin-bottom:12px;">
                    🏫 Grupa
                </div>
                <p style="margin:0; color:#334155; font-size:0.95rem; font-weight:600;">@Model.Grupa.ImeGrupe</p>
            </div>
        }

        <a asp-controller="Home" asp-action="RoditeljHome"
           style="text-align:center; color:#475569; font-size:0.88rem; text-decoration:none; padding:8px;">
            ← Nazad na početnu
        </a>

    </div>
</div>
