@model IEnumerable<EVrtic.Models.EvidencijaDolaskaOdlaska>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.VrijemeDogadjaja)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.TipDogadjaja)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.UneseniKodDjeteta)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ValidanQRKod)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.KodDjetetaIspravan)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.StatusEvidencije)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Dijete)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.DnevniQRCode)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.VrijemeDogadjaja)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.TipDogadjaja)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.UneseniKodDjeteta)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.ValidanQRKod)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.KodDjetetaIspravan)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.StatusEvidencije)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Dijete.IdentifikacioniKod)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.DnevniQRCode.VrijednostKoda)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
