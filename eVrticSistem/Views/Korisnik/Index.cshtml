@model IEnumerable<EVrtic.Models.Korisnik>

@{
    ViewData["Title"] = "Korisnici";
    ViewData["ActiveNav"] = "korisnici";
    Layout = "_AdminLayout";

    string UlogaTekst(EVrtic.Models.Uloga u) => u switch
    {
        EVrtic.Models.Uloga.RODITELJ => "Roditelj",
        EVrtic.Models.Uloga.ODGAJATELJ => "Odgajatelj",
        EVrtic.Models.Uloga.ADMINISTRATOR => "Administrator",
        _ => "Korisnik"
    };

    string AvatarEmoji(EVrtic.Models.Uloga u) => u switch
    {
        EVrtic.Models.Uloga.RODITELJ => "🧑",
        EVrtic.Models.Uloga.ODGAJATELJ => "🧑‍🏫",
        EVrtic.Models.Uloga.ADMINISTRATOR => "🛡️",
        _ => "👤"
    };
}

<div class="admin-top">
    <div>
        <h1>Korisnici</h1>
    </div>
</div>

@if (TempData["Uspjeh"] != null)
{
    <div class="admin-flash admin-flash-ok">@TempData["Uspjeh"]</div>
}
@if (TempData["Greska"] != null)
{
    <div class="admin-flash admin-flash-err">@TempData["Greska"]</div>
}

<div class="korisnici-tabs">
    <button type="button" class="korisnik-tab is-active" data-tab="svi">Svi</button>
    <button type="button" class="korisnik-tab" data-tab="roditelji">Roditelji</button>
    <button type="button" class="korisnik-tab" data-tab="odgajatelji">Odgajatelji</button>
    <button type="button" class="korisnik-tab" data-tab="administratori">Administratori</button>
</div>

<div class="admin-search">
    <span class="admin-search-ico">🔍</span>
    <input type="text" id="pretragaKorisnika" placeholder="Pretraži korisnike..." autocomplete="off" />
</div>

@if (!Model.Any())
{
    <div class="admin-empty">
        <span class="ico">👥</span>
        Trenutno nema registrovanih korisnika u sistemu.
    </div>
}
else
{
    <div class="korisnik-lista" id="korisnikLista">
        @foreach (var u in Model)
        {
            var aktivan = u.StatusNaloga == EVrtic.Models.StatusNaloga.AKTIVAN;
            var tabKey = u.Uloga switch
            {
                EVrtic.Models.Uloga.RODITELJ => "roditelji",
                EVrtic.Models.Uloga.ODGAJATELJ => "odgajatelji",
                EVrtic.Models.Uloga.ADMINISTRATOR => "administratori",
                _ => "svi"
            };
            var searchKey = ($"{u.ImePrezime} {u.Email}").ToLower();

            <div class="korisnik-stavka @(aktivan ? "" : "is-deaktiviran")"
                 data-uloga="@tabKey"
                 data-search="@searchKey">
                <div class="korisnik-avatar">@AvatarEmoji(u.Uloga)</div>
                <div class="korisnik-info">
                    <p class="korisnik-ime">
                        @u.ImePrezime
                        <span class="korisnik-uloga">(@UlogaTekst(u.Uloga))</span>
                    </p>
                    <p class="korisnik-email">@u.Email</p>
                </div>
                <div class="korisnik-akcije">
                    @if (aktivan)
                    {
                        <span class="admin-badge admin-badge-on">Aktivan</span>
                        <form asp-action="Deaktiviraj" asp-route-id="@u.Id" method="post"
                              onsubmit="return confirm('Deaktivirati nalog ovog korisnika?');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="admin-btn admin-btn-danger admin-btn-sm">Deaktiviraj</button>
                        </form>
                    }
                    else
                    {
                        <span class="admin-badge admin-badge-off">Deaktiviran</span>
                        <form asp-action="Aktiviraj" asp-route-id="@u.Id" method="post"
                              onsubmit="return confirm('Ponovo aktivirati nalog ovog korisnika?');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="admin-btn admin-btn-success admin-btn-sm">Aktiviraj</button>
                        </form>
                    }
                    <form asp-action="Obrisi" asp-route-id="@u.Id" method="post"
                          onsubmit="return confirm('Trajno OBRISATI ovog korisnika? Ovo se ne može poništiti. Veze sa djecom/grupama biće raskinute.');">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="korisnik-trash" title="Obriši korisnika">🗑️</button>
                    </form>
                </div>
            </div>
        }
    </div>

    <div class="admin-empty" id="nemaRezultata" style="display:none;">
        <span class="ico">🔎</span>
        Nema korisnika koji odgovaraju filteru.
    </div>
}

@section Scripts {
    <style>
        .korisnik-trash {
            background: transparent;
            border: none;
            cursor: pointer;
            font-size: 18px;
            padding: 6px 8px;
            border-radius: 8px;
            line-height: 1;
            opacity: .75;
            transition: background .15s, opacity .15s;
        }
        .korisnik-trash:hover {
            background: #fde2e2;
            opacity: 1;
        }
    </style>
    <script>
        (function () {
            var aktivnTab = 'svi';
            var q = '';

            var tabovi = document.querySelectorAll('.korisnik-tab');
            var input = document.getElementById('pretragaKorisnika');
            var lista = document.getElementById('korisnikLista');
            var prazno = document.getElementById('nemaRezultata');

            function primijeniFilter() {
                if (!lista) return;
                var stavke = lista.querySelectorAll('.korisnik-stavka');
                var vidljivih = 0;
                stavke.forEach(function (el) {
                    var ulogaOk = (aktivnTab === 'svi') || (el.getAttribute('data-uloga') === aktivnTab);
                    var searchOk = (q === '') || (el.getAttribute('data-search').indexOf(q) !== -1);
                    var prikaz = ulogaOk && searchOk;
                    el.style.display = prikaz ? '' : 'none';
                    if (prikaz) vidljivih++;
                });
                if (prazno) prazno.style.display = (vidljivih === 0) ? '' : 'none';
            }

            tabovi.forEach(function (btn) {
                btn.addEventListener('click', function () {
                    tabovi.forEach(function (b) { b.classList.remove('is-active'); });
                    btn.classList.add('is-active');
                    aktivnTab = btn.getAttribute('data-tab');
                    primijeniFilter();
                });
            });

            if (input) {
                input.addEventListener('input', function () {
                    q = this.value.trim().toLowerCase();
                    primijeniFilter();
                });
            }
        })();
    </script>
}
