@model EVrtic.Controllers.OdgajateljHomeViewModel

@{
    ViewData["Title"] = "Odgajatelj početna";
    var brojNovih = Model.BrojNovihObavijesti;
}

<div class="educator-page">
    <div class="educator-card">

        <aside class="educator-sidebar">
            <h1 class="educator-logo">eVrtić</h1>

            <nav class="educator-menu">
                <a class="educator-link active" asp-controller="Home" asp-action="OdgajateljHome">
                    <span>🏠</span>
                    Početna
                </a>

                <a class="educator-link" asp-controller="Obavijest" asp-action="OdgajateljObavijesti">
                    <span class="badge-icon">
                        🔔@if (brojNovih > 0) { <b>@brojNovih</b> }
                    </span>
                    Obavijesti
                </a>

                <a class="educator-link" asp-controller="Korisnik" asp-action="Profil">
                    <span>👤</span>
                    Profil
                </a>

                <form asp-area="Identity"
                      asp-page="/Account/Logout"
                      asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })"
                      method="post">
                    <button type="submit" class="educator-link educator-logout-button">
                        <span>🚪</span>
                        Odjava
                    </button>
                </form>
            </nav>

            <div class="educator-side-art">
                <div class="side-cloud side-cloud-1"></div>
                <div class="side-cloud side-cloud-2"></div>
                <div class="side-kindergarten">
                    <div class="side-roof"></div>
                    <div class="side-building">
                        <div class="side-window"></div>
                        <div class="side-door"></div>
                        <div class="side-window"></div>
                    </div>
                </div>
                <div class="side-tree side-tree-left"></div>
                <div class="side-tree side-tree-right"></div>
            </div>
        </aside>

        <main class="educator-main">
            <div class="educator-top">
                <div>
                    <h2>Pozdrav,</h2>
                    <h1>@Model.Ime! <span>☀️</span></h1>
                </div>

                <a class="educator-bell" asp-controller="Obavijest" asp-action="OdgajateljObavijesti">
                    🔔@if (brojNovih > 0) { <b class="bell-badge">@brojNovih</b> }
                </a>
            </div>

            <section class="educator-hero">
                @if (!Model.Grupe.Any())
                {
                    <div class="group-card">
                        <h3>Moja grupa</h3>
                        <div class="group-info">
                            <div class="group-avatar">🦋</div>
                            <div>
                                <h4>Niste dodjeljeni grupi</h4>
                                <p>Kontaktirajte administratora</p>
                            </div>
                        </div>
                    </div>
                }
                else if (Model.Grupe.Count == 1)
                {
                    var grupa = Model.Grupe.First();
                    <div class="group-card">
                        <h3>Moja grupa</h3>
                        <div class="group-info">
                            <div class="group-avatar">🦋</div>
                            <div>
                                <h4>@grupa.ImeGrupe</h4>
                                <p>@grupa.Djeca.Count(d => d.Aktivno) djece</p>
                            </div>
                            <a class="group-arrow" asp-controller="Grupa" asp-action="MojaGrupa">→</a>
                        </div>
                    </div>
                }
                else
                {
                    <div class="group-card">
                        <h3>Moje grupe</h3>
                        @foreach (var grupa in Model.Grupe)
                        {
                            <div class="group-info">
                                <div class="group-avatar">🦋</div>
                                <div>
                                    <h4>@grupa.ImeGrupe</h4>
                                    <p>@grupa.Djeca.Count(d => d.Aktivno) djece</p>
                                </div>
                                <a class="group-arrow" asp-controller="Grupa" asp-action="MojaGrupa">→</a>
                            </div>
                        }
                    </div>
                }

                <div class="teacher-illustration">
                    <div class="teacher-cloud teacher-cloud-1"></div>
                    <div class="teacher-cloud teacher-cloud-2"></div>
                    <div class="teacher-scene">
                        <div class="cartoon-child child-one">
                            <div class="child-head"></div>
                            <div class="child-body"></div>
                        </div>
                        <div class="cartoon-teacher">
                            <div class="teacher-head"></div>
                            <div class="teacher-body"></div>
                        </div>
                        <div class="cartoon-child child-two">
                            <div class="child-head"></div>
                            <div class="child-body"></div>
                        </div>
                        <div class="cartoon-child child-three">
                            <div class="child-head"></div>
                            <div class="child-body"></div>
                        </div>
                    </div>
                    <div class="teacher-ground"></div>
                </div>
            </section>

            <h3 class="educator-section-title">Brzi pristup</h3>

            <section class="educator-grid">
                <a class="educator-quick-card" asp-controller="DnevniIzvjestaj" asp-action="EvidencijaAktivnosti">
                    <div class="educator-quick-icon purple">📝</div>
                    <h4>Evidencija aktivnosti</h4>
                    <span>→</span>
                </a>

                <a class="educator-quick-card" asp-controller="EvidencijaDolaskaOdlaska" asp-action="Index">
                    <div class="educator-quick-icon blue">☑️</div>
                    <h4>Dolazak/Odlazak</h4>
                    <span>→</span>
                </a>

                <a class="educator-quick-card" asp-controller="Obavijest" asp-action="OdgajateljObavijesti">
                    <div class="educator-quick-icon pink">🔔</div>
                    <h4>Obavijesti</h4>
                    <span>→</span>
                </a>

                <a class="educator-quick-card" asp-controller="SazetakAktivnosti" asp-action="Index">
                    <div class="educator-quick-icon purple">📊</div>
                    <h4>Sažeci</h4>
                    <span>→</span>
                </a>
            </section>
        </main>

        <nav class="educator-bottom-nav">
            <a class="bottom-link active" asp-controller="Home" asp-action="OdgajateljHome">
                <span>🏠</span>
                Početna
            </a>
            <a class="bottom-link" asp-controller="DnevniIzvjestaj" asp-action="EvidencijaAktivnosti">
                <span>📝</span>
                Aktivnosti
            </a>
            <a class="bottom-link" asp-controller="Obavijest" asp-action="OdgajateljObavijesti">
                <span>🔔@if (brojNovih > 0) { <b class="bell-badge">@brojNovih</b> }</span>
                Obavijesti
            </a>
            <a class="bottom-link" asp-controller="Korisnik" asp-action="Profil">
                <span>👤</span>
                Profil
            </a>
        </nav>

    </div>
</div>
